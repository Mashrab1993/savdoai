# SavdoAI Web — Frontend env (Next.js)
# Copy to .env.local and set values.

# Backend API base URL (no trailing slash). Required for real auth and data.
# e.g. https://your-api.railway.app or http://localhost:8000
NEXT_PUBLIC_API_URL=

# Optional: for Telegram login, hash is computed by your bot (JWT_SECRET + user_id).
# In production use Telegram Mini App or bot to pass user_id and hash.
