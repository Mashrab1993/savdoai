# Mashrab Moliya — Bot Service
# Copy to .env and fill in real values

# ── MAJBURIY ──────────────────────────────────────────────────
BOT_TOKEN=          # Telegram bot token (@BotFather dan)
DATABASE_URL=       # postgresql://user:pass@host:5432/dbname
ANTHROPIC_API_KEY=  # Claude API key (console.anthropic.com)
GEMINI_API_KEY=     # Google Gemini API key
GEMINI_MODEL=gemini-2.5-pro

# ── ADMIN ─────────────────────────────────────────────────────
ADMIN_IDS=          # Telegram ID (vergul bilan): 123456,789012

# ── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── SERVIS URLS ───────────────────────────────────────────────
API_URL=http://localhost:8000       # API servis URL
COGNITIVE_URL=http://localhost:8001 # Cognitive engine URL
WORKER_URL=                         # Worker URL (bo'sh = standalone rejim)
# Print Telegram tugmasi: https://<web>/p/... (odatda WEB_URL = Next.js web domeni)
WEB_URL=http://localhost:3000
# PRINT_LANDING_BASE_URL=          # ixtiyoriy; bo'sh bo'lsa WEB_URL ishlatiladi

# ── DB SOZLAMALAR ─────────────────────────────────────────────
DB_MIN=2
DB_MAX=15
AI_TIMEOUT=90

# drop_pending_updates (false=ishonchli, true=tezroq restart)
DROP_PENDING=false
