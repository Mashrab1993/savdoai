# SavdoAI Web Frontend — Environment Variables
# Backend API public origin (no trailing slash). Required for all API calls.
# Local: http://localhost:8000
# Railway: copy the savdoai-api service URL (HTTPS) from the API service → Settings → Networking / public URL
# This variable is read at **build time** (next build / Docker builder stage), not only at container runtime.
NEXT_PUBLIC_API_URL=https://YOUR-API-SERVICE.up.railway.app
