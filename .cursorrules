# ═══════════════════════════════════════════════════════════════
#  2. PYTHON — BUZILMAS QOIDALAR
# ═══════════════════════════════════════════════════════════════
#
# ✅ Decimal — PUL hisoblashda FAQAT Decimal. float TAQIQLANGAN.
#    from shared.utils.hisob import D, Y, narx_hisob
#    D("45000") ✅ | float(45000) ❌
#
# ✅ asyncpg — FAQAT parametrized query:
#    await c.execute("SELECT * FROM t WHERE id=$1", uid)  ✅
#    await c.execute(f"SELECT * FROM t WHERE id={uid}")    ❌ SQL INJECTION!
#
# ✅ RLS — rls_conn(uid) DOIM ishlatiladi:
#    async with rls_conn(uid) as c:  ✅ (SET app.uid avtomatik)
#    async with pool.acquire() as c: ❌ (RLS bypass — faqat system ops)
#
# ✅ Tranzaksiya — bog'liq operatsiyalar 1 ta transaction:
#    async with c.transaction():
#        await c.execute(INSERT sessiya)
#        await c.execute(UPDATE qoldiq)    ← HAMMASI ICHIDA!
#        await c.execute(INSERT qarz)      ← HAMMASI ICHIDA!
#
# ✅ Error handling:
#    except Exception as e: log.error("...: %s", e)  ✅
#    except:  ❌ (bare except TAQIQLANGAN)
#
# ❌ TAQIQLANGAN:
#    - Bir xil nomli funksiyani 2 marta aniqlash (Python oxirgisini oladi!)
#    - add_handler ni 2 marta ro'yxatga olish
#    - print() production kodda
#    - time.sleep() async kodda (asyncio.sleep!)
#    - requests (httpx ishlatilsin)
#    - app.user_id (FAQAT app.uid — pastda §4 ko'ring)

# ═══════════════════════════════════════════════════════════════
#  3. AI STACK — 2 QATLAMLI
# ═══════════════════════════════════════════════════════════════
#
# 1-qatlam: Gemini 2.5 Pro → STT, Vision, TTS, Excel tahlil
# 2-qatlam: Claude Sonnet 4.6 → analyst (matn→JSON), suhbat, hisob-kitob
#
# STT: voice.py → DB dan 500 tovar + 200 klient → prompt
#      Qisqa (<30s) → to'g'ridan-to'g'ri Gemini
#      Uzun (>30s)  → FFmpeg → Silero VAD → Chunking → asyncio.gather
#
# Auto-learning: yangi tovar sotilsa → DB ga qo'shiladi → STT cache tozalanadi

# ═══════════════════════════════════════════════════════════════
#  4. DATABASE — XAVFSIZLIK
# ═══════════════════════════════════════════════════════════════
#
# ⚠️ RLS SETTING NOMI = app.uid (app.user_id EMAS!)
#    pool.py:    SET app.uid = '123'
#    schema.sql: current_setting('app.uid', true)::BIGINT
#    IKKALASI BIR XIL — aks holda RLS ISHLAMAYDI!
#
# Schema: shared/database/schema.sql (667 qator)
# Migratsiya: shared/migrations/versions/ (001-006)
# Segment: 16 ta (optom,chakana,oshxona,xozmak,kiyim,gosht,meva,
#                  qurilish,avto,dorixona,texnika,mebel,mato,gul,
#                  kosmetika,universal)
#
# QOIDA: schema.sql o'zgartirsang → migration ham yoz!
# QOIDA: Migration = DO $$ BEGIN ... EXCEPTION WHEN ... END $$; (xavfsiz)

# ═══════════════════════════════════════════════════════════════
#  5. TELEGRAM BOT — UX
# ═══════════════════════════════════════════════════════════════
#
# Ovoz: ⏳ darhol → STT → confidence → Claude → draft → tasdiq → saqlash
# Savat: har ovoz → savatga (klient bo'yicha) → "bo'ldi" → nakladnoy
# MarkdownV2: esc() yoki _safe_reply() DOIM ishlatilsin
# Limit: 4096 belgi → _truncate()
#
# ⚠️ CHEK CHIQAR TIZIMI (v25.3):
#    Har operatsiya (kirim/sotuv/qaytarish/qarz/nakladnoy) oxirida:
#    ctx.user_data["_oxirgi_chek_data"] = {
#        "amal": "...", "tovarlar": [...], "klient": "...", "jami_summa": N
#    }
#    "chek chiqar" desa → print_intent.py ushlaydi → bot_print_handler.py
#    → _oxirgi_chek_data dan ESC/POS printer chek chiqaradi
#    → agar data yo'q → DB dan oxirgi sotuv (fallback)
#
#    QOIDA: yangi operatsiya qo'shsang → oxirida _oxirgi_chek_data SAQLASHNI UNUTMA!

