# ═══════════════════════════════════════════════════════════════
#  1. ARXITEKTURA — HECH QACHON BUZMA
# ═══════════════════════════════════════════════════════════════

## Monorepo tuzilishi (O'ZGARTIRMA):
# savdoai-main/
# ├── services/
# │   ├── api/         → FastAPI REST (JWT + RLS + Redis cache)
# │   ├── bot/         → Telegram bot (python-telegram-bot)
# │   ├── cognitive/   → AI Router (Gemini + Claude dual-brain)
# │   ├── web/         → Next.js 16 dashboard (pnpm)
# │   └── worker/      → Celery background tasks
# ├── shared/          → Barcha servislar uchun umumiy kutubxona
# │   ├── database/    → asyncpg pool + RLS + schema.sql
# │   ├── cache/       → Redis cache
# │   ├── services/    → Business logic (ledger, pipeline, guards)
# │   ├── utils/       → hisob.py (Decimal), uzb_nlp.py, fmt.py
# │   └── rag/         → Qdrant vector DB (ixtiyoriy)
# └── tests/           → pytest (287+ test)

## Import qoidalari:
# - shared/ HAMMA servislardan import qilinadi
# - services/ bir-birini IMPORT QILMAYDI (faqat HTTP/gRPC orqali)
# - Bot → shared.database.pool, shared.utils.*, shared.services.*
# - API → shared.database.pool, shared.cache.*, shared.services.*

# ═══════════════════════════════════════════════════════════════
#  2. PYTHON QOIDALARI — QONUN KUCHIDA
# ═══════════════════════════════════════════════════════════════

## Decimal — HECH QACHON float ishlatma:
# PUL HISOBLASH FAQAT Decimal bilan. float TAQIQLANGAN.
# from shared.utils.hisob import D, Y, narx_hisob, sotuv_hisob
# D("45000") ✅ | float(45000) ❌ | 45000.0 ❌

## asyncpg — FAQAT parametrized query:
# await c.execute("SELECT * FROM t WHERE id=$1", uid)  ✅
# await c.execute(f"SELECT * FROM t WHERE id={uid}")    ❌ SQL INJECTION!
# user_yangilab — faqat _USER_YOZISH_MUMKIN fieldlar

## RLS — har doim rls_conn(uid) ishlatiladi:
# async with rls_conn(uid) as c:  ✅  (SET app.current_uid avtomatik)
# async with pool.acquire() as c: ❌  (RLS bypass — faqat system ops)

## Error handling:
# except Exception as e: log.error("...: %s", e)  ✅
# except:  ❌  (TAQIQLANGAN — bare except)
# except Exception: pass  ⚠️ (faqat fallback da, log bilan)

## async def — barcha DB/network operatsiyalar async:
# async def sotuv_saqlash(uid, data):  ✅
# def sotuv_saqlash(uid, data):        ❌ (bloklaydi!)

# ═══════════════════════════════════════════════════════════════
#  3. OVOZ PIPELINE — TEZLIK VA ANIQLIK
# ═══════════════════════════════════════════════════════════════

## 3-qatlamli AI stack:
# 1. Gemini 2.5 Pro → STT (ovoz → matn). FAQAT shu ishni qiladi.
# 2. Claude Haiku   → text_fixer (STT xatolarini tuzatadi)
# 3. Claude Sonnet  → analyst (matn → JSON, hisob-kitob)

## STT prompt — MUHIM:
# - voice.py: _build_stt_extra_for_user() → DB dan 500 tovar, 200 klient
# - Har bir user o'z tovarlarini ko'radi (RLS)
# - Cache TTL = 60s (yangi tovar 1 daqiqada Gemini ga ko'rinadi)
# - Sheva qoidalari, qarz so'zlari, pul formatlari prompt da bor

## Performance:
# - Qisqa audio (<30s): to'g'ridan-to'g'ri Gemini
# - Uzun audio (>30s): FFmpeg → Silero VAD → Chunking → asyncio.gather (PARALLEL)
# - Retry: 2 urinish, 1-8s kutish (sekin emas!)
# - N+1 query → batch SELECT (sotuv_saqlash, savat_yop)

## Auto-learning:
# - Yangi tovar sotilsa → avtomatik tovarlar jadvaliga qo'shiladi
# - STT + Fuzzy cache darhol tozalanadi
# - Keyingi ovozda Gemini yangi tovarni biladi

# ═══════════════════════════════════════════════════════════════
#  4. DATABASE — BUZILMAS QOIDALAR
# ═══════════════════════════════════════════════════════════════

## PostgreSQL schema: shared/database/schema.sql
## Migratsiyalar: shared/migrations/versions/

## RLS (Row Level Security):
# HAMMA jadvallar user_id bilan himoyalangan
# SET LOCAL app.current_uid = '123';  → rls_conn() avtomatik qiladi
# HECH QACHON qo'lda SET qilma

## Tranzaksiya:
# async with c.transaction():  → ACID kafolat
# Sotuv = sessiya + chiqimlar + qoldiq + qarz → HAMMASI 1 tranzaksiyada

## Index bo'lishi SHART:
# tovarlar(user_id, lower(nomi)) — UNIQUE
# klientlar(user_id, lower(ism)) — UNIQUE
# qarzlar(user_id, yopildi) WHERE NOT yopildi
# sotuv_sessiyalar(user_id, sana)

## Segment CHECK:
# CHECK(segment IN('optom','chakana','oshxona','xozmak','kiyim','universal'))

# ═══════════════════════════════════════════════════════════════
#  5. TELEGRAM BOT — UX QOIDALARI
# ═══════════════════════════════════════════════════════════════

## Ovoz qabul qilish:
# 1. ⏳ darhol ko'rsatiladi (foydalanuvchi kutayotganini biladi)
# 2. Uzun audio → progress callback (30%, 65%, 90%, 95%)
# 3. Low confidence → Claude ga yuboradi (rad QILMAYDI!)
# 4. Faqat "none" confidence → "qayta yuboring" deydi

## Savat tizimi (OPTOM uchun):
# - Har ovoz → savatga qo'shiladi (klient bo'yicha)
# - "Salimov bo'ldi" yoki "Salimov nakladnoy" → savat yopiladi → PDF
# - 100+ klient PARALLEL ishlaydi

## MarkdownV2 — esc() funksiyasi DOIM ishlatiladi:
# await msg.reply_text(f"Jami: {esc(pul(jami))}", parse_mode="MarkdownV2")
# Yoki _safe_reply() ishlatilsin — fallback bor

## Telegram limits:
# - Xabar: 4096 belgi max → _truncate() ishlatiladi
# - File: 50MB (Bot API), 2GB (Local Bot API)

# ═══════════════════════════════════════════════════════════════
#  6. API — XAVFSIZLIK
