# ═══════════════════════════════════════════════════════════════
#
# savdoai-main/
# ├── services/
# │   ├── api/            → FastAPI REST (1388 qator) — JWT, RLS, Redis, CORS
# │   │   ├── main.py, deps.py
# │   │   └── routes/     → kassa.py, printer.py, websocket.py
# │   ├── bot/            → Telegram bot (python-telegram-bot 21.3)
# │   │   ├── main.py     → 4846 qator — ASOSIY fayl, barcha handlerlar
# │   │   ├── db.py       → 1383 qator — DB operatsiyalar
# │   │   ├── config.py   → Config dataclass
# │   │   ├── message_handler.py → Claude suhbat
# │   │   └── bot_services/ → voice, analyst, fuzzy_matcher, nakladnoy,
# │   │                       export_pdf, export_excel, rasm_handler, tts,
# │   │                       audio_engine, voice_pipeline, offline_queue
# │   ├── cognitive/      → AI Router (Gemini + Claude dual-brain)
# │   │   ├── ai_router.py (567), engine.py (766), api.py (102)
# │   ├── web/            → Next.js 16 dashboard (41 fayl, 6506 qator)
# │   │   └── shadcn/ui, O'zbek/Rus i18n, 14 sahifa
# │   └── worker/         → Celery (tasks.py 862 qator)
# ├── shared/             → Barcha servislar uchun umumiy (27 service)
# │   ├── database/       → pool.py (RLS), schema.sql (667 qator, 19 jadval)
# │   ├── cache/          → redis_cache.py
# │   ├── services/       → ledger, pipeline, guards, ochiq_savat,
# │   │                     hisobot_engine, smart_bot_engine, smart_narx,
# │   │                     advanced_features, mutaxassis, suhbatdosh,
# │   │                     vision, hujjat_oqish, excel_reader, invoice,
# │   │                     thermal_receipt, print_session, print_intent,
# │   │                     bot_print_handler, escpos_xprinter, seed_catalog,
# │   │                     shogird_xarajat, voice_commands, voice_correction
# │   ├── utils/          → hisob.py (Decimal), uzb_nlp.py (8 sheva), fmt.py
# │   ├── rag/            → vector_db.py (Qdrant, ixtiyoriy)
# │   ├── receipt/        → normalize.py, output.py
# │   └── migrations/versions/ → 001-006 SQL migratsiyalar
# ├── android/            → Kotlin Bluetooth ESC/POS printer (985 qator)
