# Mashrab Moliya — API Service
# Copy to .env and fill in real values

# ── MAJBURIY ──────────────────────────────────────────────────
DATABASE_URL=       # postgresql://user:pass@host:5432/dbname
JWT_SECRET=         # Kuchli tasodifiy kalit (min 32 belgi)
REDIS_URL=redis://localhost:6379/0

# ── CORS (browser Origin of the Next.js app, not the API URL) ─
WEB_URL=https://savdoai-web-production.up.railway.app

# ── KOGNITIV ──────────────────────────────────────────────────
COGNITIVE_URL=http://localhost:8001

# ── DB SOZLAMALAR ─────────────────────────────────────────────
DB_MIN=5
DB_MAX=50

# ── MONITORING (ixtiyoriy) ────────────────────────────────────
SENTRY_DSN=         # Sentry DSN (bo'sh qoldirsa o'chiriladi)
DEBUG=              # "true" = /docs yoqiladi (faqat dev uchun!)

# Redis majburiyligi (true=readyz Redis down bo'lsa fail qiladi)
REDIS_REQUIRED=true
