# ═══════════════════════════════════════════
# SAVDOAI — Environment Variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════════

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/savdoai

# Redis
REDIS_URL=redis://localhost:6379

# Security — REQUIRED in production
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
PRINT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Telegram Bot
BOT_TOKEN=YOUR_BOT_TOKEN
ADMIN_IDS=YOUR_TELEGRAM_UID

# AI Keys — asosiy
ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=AIzaSyxxx

# AI Keys — qo'shimcha (plug-and-play, bo'lmasa jim o'tkaziladi)
OPENAI_API_KEY=                 # GPT-5 Pro + Whisper V3 uchun (bitta kalit)
DEEPSEEK_API_KEY=               # DeepSeek V3 (arzon batch NLP)
XAI_API_KEY=                    # Grok 4 (real-time bozor intel)

# AI Models (optional — defaults shown)
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-pro
VISION_MODEL=gemini-2.5-pro
OPENAI_MODEL=gpt-5
WHISPER_MODEL=whisper-1
DEEPSEEK_MODEL=deepseek-chat
XAI_MODEL=grok-4

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Printer (optional — defaults shown)
PRINT_DEFAULT_WIDTH=80
PRINT_LANDING_BASE_URL=
ESCPOS_CODE_PAGE=17
ESCPOS_TEXT_ENCODING=cp866

# Cognitive service
COGNITIVE_URL=http://localhost:8001
COGNITIVE_API_KEY=CHANGE_ME_openssl_rand_hex_32

# Optional
PYTHONPATH=/app
DROP_PENDING=true
SENTRY_DSN=

# ═══ v25.3.2 YANGI SOZLAMALAR ═══

# Click.uz to'lov integratsiya
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# Payme.uz to'lov integratsiya
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
