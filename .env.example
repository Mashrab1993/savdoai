# ═══ MASHRAB MOLIYA v21.3 ═══
# Barcha servislar uchun muhit o'zgaruvchilari

# ── ASOSIY (MAJBURIY) ──
BOT_TOKEN=
DATABASE_URL=postgresql://user:pass@host:5432/mashrab
# Bot polling Conflict oldini olish uchun SHART (bir nechta instance bo'lsa). Redis yo'q bo'lsa faqat 1 ta bot replica ishlating.
REDIS_URL=redis://host:6379/0
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
JWT_SECRET=min-32-belgili-tasodifiy-kalit
ADMIN_IDS=123456789,987654321

# ── SERVIS URL LAR ──
COGNITIVE_URL=https://mashrab-cognitive.railway.app
WORKER_URL=https://mashrab-worker.railway.app
WEB_URL=https://mashrab-moliya.vercel.app

# ── IXTIYORIY ──
SENTRY_DSN=
QDRANT_URL=
QDRANT_API_KEY=
DEBUG=false
# true = restart da kutilayotgan update'lar o'chiriladi (Conflict bo'lganda ba'zan yordam beradi)
DROP_PENDING=false

# ── DB POOL ──
DB_MIN=2
DB_MAX=20

# ── AI MODELLARI ──
GEMINI_MODEL=gemini-3.1-flash-lite

# ── HISOBOT VAQTLARI ──
KUNLIK_SOAT=22
HAFTALIK_SOAT=8
QARZ_SOAT=10
OBUNA_SOAT=9
