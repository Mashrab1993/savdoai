# ═══════════════════════════════════════════
# SAVDOAI — Environment Variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════════

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/savdoai

# Redis
REDIS_URL=redis://localhost:6379

# Security — REQUIRED in production
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
PRINT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Telegram Bot
BOT_TOKEN=YOUR_BOT_TOKEN
ADMIN_IDS=YOUR_TELEGRAM_UID

# AI Keys
ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=AIzaSyxxx

# AI Models (optional — defaults shown)
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-pro
VISION_MODEL=gemini-2.5-pro

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Printer (optional — defaults shown)
PRINT_DEFAULT_WIDTH=80
PRINT_LANDING_BASE_URL=
ESCPOS_CODE_PAGE=17
ESCPOS_TEXT_ENCODING=cp866

# Cognitive service
COGNITIVE_URL=http://localhost:8001

# Optional
PYTHONPATH=/app
DROP_PENDING=true
SENTRY_DSN=
